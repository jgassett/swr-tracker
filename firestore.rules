rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    /* Admin gate — mirrors ADMIN_EMAILS in the app and in Cloud Functions. */
    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['jon@southern-wildlife.com'];
    }

    /* Trap records — shared by all three trappers. */
    match /records/{recordId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Pesticide master database — admin manages, all read. */
    match /pesticides/{pesticideId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Pesticide application records — shared. */
    match /pesticide_records/{recordId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Customer directory — shared CRM across trapping + pesticide modules.
       Created manually in-app now; a future QuickBooks → Firestore sync will
       write here too. The app-controlled `active` flag is never touched by
       that sync. Same auth pattern as the other shared collections. */
    match /customers/{customerId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid;
      /* Shared edits are fine, but qbId (the QuickBooks CustomerRef used by the
         estimate/invoice push) is set only by the QB sync / qbCreateCustomer
         function via the Admin SDK — clients may never change it. */
      allow update: if signedIn()
                    && request.resource.data.get('qbId', null) == resource.data.get('qbId', null);
      allow delete: if signedIn();
    }

    /* Customer properties subcollection (Item 9). Matched as a collection
       group so the app can list every property (camera-key matching, form
       selectors). Same auth pattern as the other shared collections. */
    match /{path=**}/properties/{propertyId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn();
    }

    /* Job estimates (Pricing Constructor). Shared like the other collections.
       The approve → QuickBooks push happens server-side in an admin-gated
       Cloud Function (qbPushEstimate), which writes qbEstimateId / the
       "Pushed to QB" status via the Admin SDK (bypassing these rules). */
    match /estimates/{estimateId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid;

      /* Admin may make any client-side change (e.g. Reject). The approve → push
         and convert-to-invoice writes come from Cloud Functions via the Admin
         SDK and bypass these rules. A non-admin owner may edit or submit their
         OWN estimate only while it is still Draft or Rejected, may not change
         its ownership, and may never self-promote it to a QuickBooks state. */
      allow update: if isAdmin()
                    || (signedIn()
                        && resource.data.createdByUid == request.auth.uid
                        && resource.data.status in ['Draft', 'Rejected']
                        && request.resource.data.createdByUid == resource.data.createdByUid
                        && !(request.resource.data.status in ['Pushed to QB', 'Invoiced']));

      /* Deletable only before it reaches QuickBooks — enforces at the rules
         layer what the app previously only checked client-side. */
      allow delete: if signedIn()
                    && resource.data.status in ['Draft', 'Pending Approval', 'Rejected'];
    }

    /* Jobs (v2 lifecycle containers + legacy Phase-4 schedule docs). Shared
       across the crew like the other collections; assignees are notified
       server-side (notifyJobAssignment, Admin SDK) which also reads jobs to
       build the push payload. */

    /* Lifecycle position of a v2 job status. Mirrors JOB_STATUSES in the
       app; unknown statuses rank -1 and so can never be written.
       v2-patch-1 Item 15: task-model jobs use Active → Complete/Cancelled;
       'Complete' ranks above every legacy status so the forward-only guard
       admits it while still blocking regressions. */
    function jobStatusRank(s) {
      return {'Lead': 0, 'Estimated': 1, 'Scheduled': 2, 'Active': 3,
              'Pending Close': 4, 'Invoiced': 5, 'Paid': 6,
              'Complete': 7}.get(s, -1);
    }

    /* Forward-only status guard for v2 lifecycle jobs (they carry a
       jobNumber; legacy schedule docs keep the v1 shared-edit behavior).
       A client update may keep the status as-is, cancel a not-yet-cancelled
       job, or move it forward in the progression — never backward, never
       out of Cancelled, never to an unknown status. Blocks a stale offline
       write from regressing a job another device already advanced. */
    function jobStatusMoveOk() {
      return !('jobNumber' in resource.data)
        || request.resource.data.get('status', null) == resource.data.get('status', null)
        || (resource.data.get('status', 'Lead') != 'Cancelled'
            && (request.resource.data.get('status', null) == 'Cancelled'
                || jobStatusRank(request.resource.data.get('status', ''))
                     > jobStatusRank(resource.data.get('status', 'Lead'))));
    }

    /* Close Out is admin-only (v2-patch-3 Fix 1) — mirrors the isAdmin()
       gate the app puts on confirmCloseOutJob(). Any operator may update
       other job fields or make other status moves; only an admin may
       TRANSITION a job to Complete. Updates that leave an already-Complete
       job's status untouched stay open to everyone. */
    function completeTransitionIsAdmin() {
      return request.resource.data.get('status', null) != 'Complete'
        || resource.data.get('status', null) == 'Complete'
        || isAdmin();
    }

    /* rebaitActive guard (v2-patch-3 Fix 2): a write may only leave
       rebaitActive == true on a job whose resulting status is Active —
       so no one can (re)activate the rebait schedule on a Complete or
       Cancelled job, or keep it alive while closing the job out. Setting
       or leaving it false is always fine. (jobStatusMoveOk already stops
       Complete/Cancelled from regressing to Active, so the two checks
       together make rebait reactivation on a closed job impossible.) */
    function rebaitActiveOk() {
      /* v2-patch-6 Item 15: strict boolean — a truthy non-boolean (1, "yes")
         used to slip past the old `!= true` check. Now the field must be
         exactly false, or exactly true on a job whose resulting status is
         Active. */
      return request.resource.data.get('rebaitActive', false) == false
        || (request.resource.data.get('rebaitActive', false) == true
            && request.resource.data.get('status', 'Active') == 'Active');
    }

    /* Job-number allocation counter (M4) — read and bumped inside a client
       transaction by any signed-in operator. */
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }

    match /jobs/{jobId} {
      allow read:   if request.auth != null;
      /* v2-patch-6 Item 15 (M1 follow-up): the lifecycle guards apply at
         CREATE too — a job can't be born directly into Complete by a
         non-admin, and can't be born with rebait armed on a non-Active
         status. Closes the delete-and-recreate bypass path. */
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid
                    && (request.resource.data.get('status', 'Lead') != 'Complete' || isAdmin())
                    && rebaitActiveOk();
      /* v2-patch-6 Item 15 (M1): jobNumber is immutable — deleting it from
         a doc used to strip every lifecycle guard from later writes. */
      allow update: if request.auth != null
                    && jobStatusMoveOk()
                    && completeTransitionIsAdmin()
                    && rebaitActiveOk()
                    && request.resource.data.get('jobNumber', null) == resource.data.get('jobNumber', null);
      /* v2-patch-6 Item 15 (M1): lifecycle jobs (jobNumber present) are
         admin-delete only, so delete-and-recreate can't bypass the status
         guards; legacy schedule docs stay crew-deletable (the app's only
         client-side job delete is on legacy docs). */
      allow delete: if request.auth != null
                    && (isAdmin() || !('jobNumber' in resource.data));
    }

    /* Tasks (v2-patch-1 Item 15) — top-level collection; each task belongs
       to a job (jobId). Shared across the crew like the other collections. */
    match /tasks/{taskId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Appointments subcollection under jobs (v2). Matched as a collection
       group so the app can query every job's appointments for the shared
       Schedule calendar. Only jobs carry an `appointments` subcollection.
       Same auth pattern as the other shared collections. */
    match /{path=**}/appointments/{appointmentId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Seeded price-list reference (read by all; seeded in-app). */
    match /priceList/{itemId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Camera photos (Field Information module). Written server-side by the
       Cuddeback ingestion function (Admin SDK, bypasses rules); clients read,
       may reassign an unmatched photo to a customer, and (v2-patch-5 Item 4)
       may stamp their own email into the per-operator `deletedBy` array.
       Deleting the document entirely is admin-only — operator "deletes" only
       hide the photo from that operator's view. */
    match /cameraPhotos/{photoId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if isAdmin();
    }

    /* Per-camera lastSeen tracking (Item 14) — written server-side by the
       photo pipeline and read by the watchdog; clients read only.
       v2-patch-5 Item 21: the admin may UPDATE a row to confirm a pending
       camera removal (removalConfirmed flags) — mirrors the app's
       admin-gated Confirm Camera Removal button. */
    match /cameraStatus/{cameraKey} {
      allow read:   if request.auth != null;
      allow update: if isAdmin();
      allow create, delete: if false;
    }

    /* Camera health snapshots (per device), written server-side from the daily
       report. Clients may only DELETE a row — used by "Delete Photos From App"
       to clear a retired camera; the ingest recreates rows if that camera
       reports again. */
    match /cameraHealth/{deviceId} {
      allow read:   if request.auth != null;
      allow create, update: if false;
      allow delete: if request.auth != null;
    }

    /* In-app notifications (Item 12). Each operator can only READ and WRITE
       (mark read / dismiss) their own notifications. Client-side creation
       exists solely for the job-status-change teammate notice, so creates
       are locked to that exact shape (unread, type 'job', bounded strings,
       not addressed to yourself). Server-side alerts use the Admin SDK and
       bypass these rules anyway. */
    match /notifications/{notificationId} {
      allow read:   if signedIn()
                    && resource.data.recipientEmail == request.auth.token.email.lower();
      allow create: if signedIn()
                    && request.auth.token.email != null
                    && request.resource.data.keys().hasOnly(
                         ['recipientEmail', 'type', 'title', 'body', 'relatedId', 'read', 'createdAt'])
                    && request.resource.data.recipientEmail is string
                    && request.resource.data.recipientEmail != request.auth.token.email.lower()
                    && request.resource.data.type == 'job'
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.body is string
                    && request.resource.data.body.size() <= 500
                    && request.resource.data.read == false
                    && request.resource.data.createdAt is string;
      allow update: if signedIn()
                    && resource.data.recipientEmail == request.auth.token.email.lower();
      allow delete: if signedIn()
                    && resource.data.recipientEmail == request.auth.token.email.lower();
    }

    /* Private per-operator notes (Item 7, v2-patch-6). OWNER-ONLY read and
       write — matched on the signed-in UID against the note's ownerUid.
       There is deliberately NO admin exception: the admin cannot read
       other operators' notes. Creates must stamp the caller's own uid and
       a bounded shape; updates may never reassign ownership. */
    match /notes/{noteId} {
      allow read:   if signedIn()
                    && resource.data.ownerUid == request.auth.uid;
      allow create: if signedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.keys().hasOnly(
                         ['ownerUid', 'ownerEmail', 'title', 'body', 'createdAt', 'updatedAt'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.body is string
                    && request.resource.data.body.size() <= 20000;
      allow update: if signedIn()
                    && resource.data.ownerUid == request.auth.uid
                    && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if signedIn()
                    && resource.data.ownerUid == request.auth.uid;
    }

    /* Graph API 401 diagnostics (Item 7) — written server-side by the email
       pipeline (Admin SDK); clients read for visibility only. */
    match /graphErrors/{errorId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    /* Photo retention audit log (v2-patch-1 Item 4) — written server-side by
       cleanupCameraPhotos (Admin SDK); clients read for visibility only. */
    match /photoCleanupLog/{logId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    /* Web-push device tokens. Clients register/remove their own; only the
       Admin SDK (server) reads them to send notifications. */
    match /pushTokens/{tokenId} {
      allow read:  if false;
      allow create, update, delete: if request.auth != null;
    }

    /* Org-level settings (business name, permit, applicator certs, etc.). */
    match /org/{docId} {
      allow read:  if signedIn();
      /* Business name, permit numbers, applicator certs and photo-retention are
         admin-only (the app already gates the UI on isAdmin). */
      allow write: if isAdmin();
    }

    /* Deny everything else by default. */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
