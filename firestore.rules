rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    /* Admin gate — mirrors ADMIN_EMAILS in the app and in Cloud Functions. */
    function isAdmin() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['jon@southern-wildlife.com', 'tanya@southern-wildlife.com'];
    }

    /* Trap records — shared by all three trappers. */
    match /records/{recordId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Pesticide master database — admin manages, all read. */
    match /pesticides/{pesticideId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Pesticide application records — shared. */
    match /pesticide_records/{recordId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Customer directory — shared CRM across trapping + pesticide modules.
       Created manually in-app now; a future QuickBooks → Firestore sync will
       write here too. The app-controlled `active` flag is never touched by
       that sync. Same auth pattern as the other shared collections. */
    match /customers/{customerId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid;
      /* Shared edits are fine, but qbId (the QuickBooks CustomerRef used by the
         estimate/invoice push) is set only by the QB sync / qbCreateCustomer
         function via the Admin SDK — clients may never change it. */
      allow update: if signedIn()
                    && request.resource.data.get('qbId', null) == resource.data.get('qbId', null);
      allow delete: if signedIn();
    }

    /* Customer properties subcollection (Item 9). Matched as a collection
       group so the app can list every property (camera-key matching, form
       selectors). Same auth pattern as the other shared collections. */
    match /{path=**}/properties/{propertyId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn();
    }

    /* Job estimates (Pricing Constructor). Shared like the other collections.
       The approve → QuickBooks push happens server-side in an admin-gated
       Cloud Function (qbPushEstimate), which writes qbEstimateId / the
       "Pushed to QB" status via the Admin SDK (bypassing these rules). */
    match /estimates/{estimateId} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.createdByUid == request.auth.uid;

      /* Admin may make any client-side change (e.g. Reject). The approve → push
         and convert-to-invoice writes come from Cloud Functions via the Admin
         SDK and bypass these rules. A non-admin owner may edit or submit their
         OWN estimate only while it is still Draft or Rejected, may not change
         its ownership, and may never self-promote it to a QuickBooks state. */
      allow update: if isAdmin()
                    || (signedIn()
                        && resource.data.createdByUid == request.auth.uid
                        && resource.data.status in ['Draft', 'Rejected']
                        && request.resource.data.createdByUid == resource.data.createdByUid
                        && !(request.resource.data.status in ['Pushed to QB', 'Invoiced']));

      /* Deletable only before it reaches QuickBooks — enforces at the rules
         layer what the app previously only checked client-side. */
      allow delete: if signedIn()
                    && resource.data.status in ['Draft', 'Pending Approval', 'Rejected'];
    }

    /* Jobs (v2 lifecycle containers + legacy Phase-4 schedule docs). Shared
       across the crew like the other collections; assignees are notified
       server-side (notifyJobAssignment, Admin SDK) which also reads jobs to
       build the push payload. */
    match /jobs/{jobId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Appointments subcollection under jobs (v2). Matched as a collection
       group so the app can query every job's appointments for the shared
       Schedule calendar. Only jobs carry an `appointments` subcollection.
       Same auth pattern as the other shared collections. */
    match /{path=**}/appointments/{appointmentId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Seeded price-list reference (read by all; seeded in-app). */
    match /priceList/{itemId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Camera photos (Field Information module). Written server-side by the
       Cuddeback ingestion function (Admin SDK, bypasses rules); clients read,
       and may reassign an unmatched photo to a customer. */
    match /cameraPhotos/{photoId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Camera health snapshots (per device), written server-side from the daily
       report. Clients may only DELETE a row — used by "Delete Photos From App"
       to clear a retired camera; the ingest recreates rows if that camera
       reports again. */
    match /cameraHealth/{deviceId} {
      allow read:   if request.auth != null;
      allow create, update: if false;
      allow delete: if request.auth != null;
    }

    /* Graph API 401 diagnostics (Item 7) — written server-side by the email
       pipeline (Admin SDK); clients read for visibility only. */
    match /graphErrors/{errorId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    /* Web-push device tokens. Clients register/remove their own; only the
       Admin SDK (server) reads them to send notifications. */
    match /pushTokens/{tokenId} {
      allow read:  if false;
      allow create, update, delete: if request.auth != null;
    }

    /* Org-level settings (business name, permit, applicator certs, etc.). */
    match /org/{docId} {
      allow read:  if signedIn();
      /* Business name, permit numbers, applicator certs and photo-retention are
         admin-only (the app already gates the UI on isAdmin). */
      allow write: if isAdmin();
    }

    /* Deny everything else by default. */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
