rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* Trap records — shared by all three trappers. */
    match /records/{recordId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Pesticide master database — admin manages, all read. */
    match /pesticides/{pesticideId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Pesticide application records — shared. */
    match /pesticide_records/{recordId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Customer directory — shared CRM across trapping + pesticide modules.
       Created manually in-app now; a future QuickBooks → Firestore sync will
       write here too. The app-controlled `active` flag is never touched by
       that sync. Same auth pattern as the other shared collections. */
    match /customers/{customerId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Job estimates (Pricing Constructor). Shared like the other collections.
       The approve → QuickBooks push happens server-side in an admin-gated
       Cloud Function (qbPushEstimate), which writes qbEstimateId / the
       "Pushed to QB" status via the Admin SDK (bypassing these rules). */
    match /estimates/{estimateId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Seeded price-list reference (read by all; seeded in-app). */
    match /priceList/{itemId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Camera photos (Field Information module). Written server-side by the
       Cuddeback ingestion function (Admin SDK, bypasses rules); clients read,
       and may reassign an unmatched photo to a customer. */
    match /cameraPhotos/{photoId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    /* Camera health snapshots (per device), written server-side from the daily
       report; clients read only. */
    match /cameraHealth/{deviceId} {
      allow read:  if request.auth != null;
      allow write: if false;
    }

    /* Org-level settings (business name, permit, applicator certs, etc.). */
    match /org/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    /* Deny everything else by default. */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
